# ── .env.template ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it's in .gitignore.

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure AI Search (long-term memory for past reports) ───────────────────────
AZURE_SEARCH_ENDPOINT=https://YOUR_SEARCH_RESOURCE.search.windows.net
AZURE_SEARCH_KEY=your_azure_search_key_here
AZURE_SEARCH_INDEX=financial-reports

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=financial-analysis-agent
